{
  "name": "bns-studio-dashboard",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace @bns/web run dev",
    "dev:desktop": "npm --workspace @bns/desktop run dev",
    "build": "npm run build:web && npm run build:desktop",
    "build:web": "npm --workspace @bns/web run build",
    "build:desktop": "npm --workspace @bns/desktop run build",
    "typecheck": "npm --workspace @bns/web run typecheck && npm --workspace @bns/api run typecheck",
    "lint": "npm --workspace @bns/web run lint",
    "test": "npm --workspace @bns/web run test",
    "test:watch": "npm --workspace @bns/web run test:watch"
  },
  "devDependencies": {
    "supabase": "^2.109.1"
  }
}
